#!/bin/sh
#----------------------------------------------------------------------------
# /etc/rc.d/rc121.virtio-net - loading virtio network driver
#
# Creation:     04.03.2019  florian
# Last Update:  $Id: rc121.virtio-net 56794 2019-09-23 13:04:38Z florian $
#----------------------------------------------------------------------------

begin_script NET "loading virtio network drivers ..."

load_driver virtio_pci ""
load_driver virtio_net ""

end_script

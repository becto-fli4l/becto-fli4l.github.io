#!/bin/sh
#----------------------------------------------------------------------------
# /etc/ppp/ip-up100.6in4-he                                      __FLI4LVER__
#
# Last Update:  $Id: ipv6-up100.tun6in4-he 30827 2014-05-05 14:38:16Z kristov $
#----------------------------------------------------------------------------

if [ -f /var/run/dynamic.ip ]
then
    case $circ_type:$circ_tun6in4_type in
    tun6in4:he)
        ipup-he.sh "$(cat /var/run/dynamic.ip)"
    ;;
    esac
fi
